---
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
import AppShell from "../../layouts/AppShell.astro";
import { APP_META } from "../../app.meta";

const title = `${APP_META.name} App`;
const description = "Protected app entry for the Ansiversa mini-app starter.";

const nextSteps = [
  "Replace this page with your app dashboard or primary workflow.",
  "Keep parent-auth redirects and route your signed-in experience through /app.",
  "Update APP_META before building the next mini-app so naming stays correct everywhere.",
];
---

<AppShell title={title} description={description}>
  <section class="av-section">
    <AvContainer>
      <div class="av-auth-stack-lg">
        <AvCard className="av-auth-card">
          <div class="av-auth-stack-md">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Authenticated Area</p>
              <h1 class="av-section-title">{APP_META.name}</h1>
              <p class="av-text-soft">
                This is the protected entry point for the mini-app. Authenticated users should land
                here after sign-in and continue into the real product workflow from this route.
              </p>
            </div>

            <div class="av-row-wrap">
              <AvButton href="/">Back to landing</AvButton>
              <AvButton href="/signout" variant="ghost">Sign out</AvButton>
            </div>
          </div>
        </AvCard>

        <div class="grid gap-4 md:grid-cols-3">
          {nextSteps.map((step) => (
            <AvCard variant="soft" className="av-auth-stack-sm">
              <h2 class="av-card-heading">Next step</h2>
              <p class="av-text-soft">{step}</p>
            </AvCard>
          ))}
        </div>
      </div>
    </AvContainer>
  </section>
</AppShell>
